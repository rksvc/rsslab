{
  "name": "rsslab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev",
    "bundle": "rsbuild build",
    "lint": "tsc && biome check",
    "serve": "go run -tags=sqlite_foreign_keys . -addr=:1234",
    "build_windows": "CC='zig cc -target x86_64-windows-gnu -Wl,--subsystem,windows' CGO_ENABLED=1 GOOS=windows go build -tags=sqlite_foreign_keys -ldflags='-s -w -H=windowsgui' -trimpath"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.15.1",
    "immer": "^11.1.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-feather": "^2.0.10",
    "use-immer": "^0.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rsbuild/core": "^2.0.11",
    "@rsbuild/plugin-react": "^2.0.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
